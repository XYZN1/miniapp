.panel {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: rgba(26,14,10,0.95);
  border-top: 2rpx solid #5a4a3a;
  padding: 24rpx 30rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  transform: translateY(100%); transition: transform 0.3s;
}
.panel.show { transform: translateY(0); }
.phase-indicator { text-align: center; margin-bottom: 16rpx; }
.phase-text { font-size: 24rpx; color: #8b7355; }
.actions-row { display: flex; justify-content: center; gap: 20rpx; }
.action-btn {
  flex: 1; padding: 20rpx; border-radius: 12rpx;
  font-size: 28rpx; font-weight: bold; border: none; text-align: center;
}
.action-btn.play { background: linear-gradient(135deg, #c9a84c, #a67c2e); color: #2c1810; }
.action-btn.challenge { background: linear-gradient(135deg, #c0392b, #96281b); color: #fff; }
.action-btn.follow { background: linear-gradient(135deg, #27ae60, #1e8449); color: #fff; }
.action-btn.pass { background: rgba(255,255,255,0.1); color: #e8d5b7; }
.action-btn.disabled { opacity: 0.4; }
.waiting { text-align: center; font-size: 28rpx; color: #8b7355; }
