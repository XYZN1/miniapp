.panel {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: linear-gradient(0deg, #1a0e0a, rgba(26,14,10,0.95));
  border-top: 2rpx solid #5a4a3a;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  transform: translateY(100%); transition: transform 0.3s;
  z-index: 50;
}
.panel.show { transform: translateY(0); }
.phase-indicator { text-align: center; margin-bottom: 12rpx; }
.phase-text { font-size: 22rpx; color: #8b7355; }
.play-hint { text-align: center; font-size: 22rpx; color: #c9a84c; margin-bottom: 8rpx; }
.actions-row { display: flex; justify-content: center; gap: 16rpx; }
.action-btn {
  flex: 1; max-width: 220rpx;
  padding: 24rpx 16rpx; border-radius: 14rpx;
  font-size: 30rpx; font-weight: bold; border: none; text-align: center;
  transition: opacity 0.2s, transform 0.15s;
}
.action-btn:active { transform: scale(0.96); }
.action-btn.play { background: linear-gradient(135deg, #c9a84c, #a67c2e); color: #2c1810; }
.action-btn.challenge { background: linear-gradient(135deg, #c0392b, #96281b); color: #fff; }
.action-btn.follow { background: linear-gradient(135deg, #27ae60, #1e8449); color: #fff; }
.action-btn.pass { background: rgba(255,255,255,0.12); color: #e8d5b7; border: 2rpx solid #5a4a3a; }
.action-btn.disabled { opacity: 0.35; }
.waiting {
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
  font-size: 26rpx; color: #8b7355; padding: 12rpx 0;
}
.waiting-spinner { width: 16rpx; height: 16rpx; border-radius: 50%; background: #c9a84c; animation: blink 1s infinite; }
@keyframes blink { 0%,100% { opacity: 0.3; } 50% { opacity: 1; } }
