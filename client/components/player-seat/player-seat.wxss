.seat {
  display: flex; flex-direction: column; align-items: center;
  gap: 8rpx; padding: 12rpx 16rpx; border-radius: 12rpx; opacity: 0.8;
  transition: all 0.3s;
}
.seat.active { opacity: 1; background: rgba(201,168,76,0.15); border: 2rpx solid #c9a84c; }
.seat.dead { opacity: 0.3; }
.avatar-circle { width: 64rpx; height: 64rpx; border-radius: 50%; background: #5a4a3a; display: flex; align-items: center; justify-content: center; }
.avatar-text { font-size: 28rpx; color: #e8d5b7; }
.nickname { font-size: 22rpx; color: #e8d5b7; }
.lives { display: flex; gap: 4rpx; }
.card-count { font-size: 20rpx; color: #8b7355; }
