.game-container {
  display: flex; flex-direction: column; height: 100vh;
  background: #1a0e0a;
  color: #e8d5b7;
}

/* 顶栏 */
.top-bar {
  display: flex; justify-content: space-between; align-items: center;
  padding: 16rpx 24rpx;
  background: linear-gradient(180deg, #2c1810, #1a0e0a);
  border-bottom: 2rpx solid #5a4a3a;
  z-index: 10;
}
.round-info, .pile-info { font-size: 24rpx; color: #8b7355; }
.target-rank { text-align: center; }
.target-label { font-size: 20rpx; color: #8b7355; display: block; }
.target-value { font-size: 52rpx; font-weight: bold; color: #c9a84c; display: block; line-height: 1.1; }

/* 桌面 */
.table-area {
  flex: 1; display: flex; align-items: center; justify-content: center;
  padding: 10rpx 20rpx; overflow: hidden;
}
.table-felt {
  width: 100%; height: 100%;
  background: radial-gradient(ellipse at center, #1e4d2b 0%, #143820 50%, #0d2816 100%);
  border-radius: 30rpx;
  border: 4rpx solid #5a4a3a;
  display: flex; flex-direction: column;
  position: relative; box-shadow: inset 0 0 60rpx rgba(0,0,0,0.5);
}

.opponents-row {
  display: flex; justify-content: space-around;
  padding: 16rpx 16rpx 0;
}
.opponent-group { display: flex; flex-direction: column; align-items: center; gap: 6rpx; }
.played-cards { display: flex; gap: 4rpx; }
.played-card { width: 50rpx; height: 70rpx; }
.table-center {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center;
}
.center-icon { font-size: 64rpx; margin-bottom: 8rpx; }
.center-label { font-size: 24rpx; color: rgba(232,213,183,0.6); }

/* 手牌区 */
.my-played-area {
  padding: 8rpx 20rpx;
  background: rgba(0,0,0,0.15);
}
.my-played-label { font-size: 20rpx; color: #8b7355; display: block; margin-bottom: 4rpx; text-align: center; }
.my-played-cards { display: flex; justify-content: center; gap: 4rpx; }
.my-played-card { width: 56rpx; height: 78rpx; }
.hand-area {
  padding: 10rpx 0 220rpx;
  background: linear-gradient(0deg, #2c1810, transparent);
}
.hand-cards {
  display: flex; justify-content: center; gap: 6rpx;
  padding: 0 16rpx; perspective: 600rpx;
}
.card-slot {
  width: 116rpx; height: 162rpx;
  transition: transform 0.2s, margin-top 0.2s;
  transform-style: preserve-3d;
}
.card-slot.selected { transform: translateY(-40rpx) scale(1.08); }
.hand-cards.active .card-slot { cursor: pointer; }
.hand-tip { text-align: center; font-size: 28rpx; color: #8b7355; padding: 40rpx; }

/* 结果浮层 */
.result-overlay {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.7);
  display: flex; align-items: center; justify-content: center;
  z-index: 100; opacity: 0; pointer-events: none;
  transition: opacity 0.3s;
}
.result-overlay.show { opacity: 1; pointer-events: auto; }
.result-card {
  background: linear-gradient(135deg, #2c1810, #4a2c1a);
  border: 2rpx solid #c9a84c;
  border-radius: 24rpx; padding: 40rpx 48rpx;
  text-align: center; min-width: 400rpx;
}
.result-icon { font-size: 80rpx; display: block; margin-bottom: 16rpx; }
.result-title { font-size: 36rpx; font-weight: bold; color: #c9a84c; display: block; margin-bottom: 12rpx; }
.result-desc { font-size: 28rpx; color: #d4c5a9; display: block; margin-bottom: 32rpx; }
