.container { padding: 30rpx; min-height: 100vh; display: flex; flex-direction: column; }
.room-header {
  display: flex; justify-content: space-between; align-items: center;
  padding: 20rpx; background: rgba(255,255,255,0.05);
  border-radius: 16rpx; margin-bottom: 40rpx;
}
.room-code { font-size: 36rpx; font-weight: bold; color: #c9a84c; letter-spacing: 6rpx; }
.player-count { font-size: 28rpx; color: #8b7355; }
.player-list { flex: 1; display: flex; flex-direction: column; gap: 20rpx; }
.player-item {
  display: flex; align-items: center; padding: 24rpx;
  background: rgba(255,255,255,0.05); border-radius: 12rpx;
}
.player-name { flex: 1; font-size: 32rpx; }
.player-status { font-size: 24rpx; color: #666; margin-right: 16rpx; }
.player-status.ready { color: #27ae60; }
.player-host { font-size: 22rpx; color: #c9a84c; background: rgba(201,168,76,0.15); padding: 4rpx 12rpx; border-radius: 8rpx; }
.room-actions { display: flex; flex-direction: column; gap: 20rpx; margin-top: 40rpx; }
