<view class="container">
  <view class="logo-section">
    <text class="logo-icon">🃏</text>
    <text class="title">骗子酒馆</text>
    <text class="subtitle">虚张声势 · 真假难辨</text>
  </view>
  <view class="action-section">
    <view class="input-group">
      <input class="room-input" placeholder="输入房间号" maxlength="6"
        bindinput="onRoomIdInput" value="{{roomId}}" />
    </view>
    <view class="btn-group">
      <button class="btn-primary" bindtap="onCreateRoom">创建房间</button>
      <button class="btn-secondary" bindtap="onJoinRoom" disabled="{{!roomIdInput}}">加入房间</button>
    </view>
  </view>
  <view class="rules-link" bindtap="onGoRules">游戏规则</view>
</view>
