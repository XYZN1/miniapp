<view class="game-container">
  <!-- 顶部信息栏 -->
  <view class="top-bar">
    <view class="top-left">
      <text class="round-info">第 {{roundNumber}} 轮</text>
      <view class="countdown-self {{countdownUrgent ? "urgent" : ""}}" wx:if="{{countdownRunning}}">{{countdownCurrent}}</view>
    </view>
    <view class="target-rank">
      <text class="target-label">目标点数</text>
      <text class="target-value">{{targetRank}}</text>
    </view>
    <text class="pile-info">牌堆 {{centralPileCount}} 张</text>
  </view>

  <!-- 桌面中央 -->
  <view class="table-area">
    <view class="table-felt">
      <view class="opponents-row">
        <player-seat
          wx:for="{{opponents}}" wx:key="id"
          nickname="{{item.nickname}}"
          lives="{{item.lives}}"
          cardCount="{{item.handCardCount}}"
          isActive="{{item.id === currentPlayerId}}"
          isAlive="{{item.isAlive}}"
        ></player-seat>
      </view>
      <view class="table-center">
        <text class="center-icon">🃏</text>
        <text class="center-label">{{centralPileCount > 0 ? '已出 ' + centralPileCount + ' 张' : '等待出牌'}}</text>
      </view>
    </view>
  </view>

  <!-- 已出牌区域 -->
  <view class="my-played-area" wx:if="{{myPlayedCards.length > 0}}">
    <text class="my-played-label">我出的牌</text>
    <view class="my-played-cards">
      <view class="my-played-card" wx:for="{{myPlayedCards}}" wx:key="cardId">
        <card cardId="{{item.cardId}}" faceUp="{{true}}"></card>
      </view>
    </view>
  </view>

  <!-- 手牌区域 -->
  <view class="hand-area">
    <view class="hand-cards {{isMyTurn ? 'active' : ''}}">
      <view
        class="card-slot {{item.selected ? 'selected' : ''}}"
        wx:for="{{handCards}}" wx:key="id"
        bindtap="onSelectCard" data-id="{{item.id}}"
      >
        <card cardId="{{item.id}}" faceUp="{{true}}"></card>
      </view>
    </view>
    <view class="hand-tip" wx:if="{{!handCards.length}}">等待发牌...</view>
  </view>

  <!-- 操作面板 -->
  <action-panel
    isMyTurn="{{isMyTurn}}"
    gamePhase="{{gamePhase}}"
    selectedCards="{{selectedCards}}"
    currentPlayerName="{{currentPlayerName}}"
    bind:playcards="onPlayCards"
    bind:challenge="onChallenge"
    bind:follow="onFollow"
    bind:pass="onPass"
  ></action-panel>

  <!-- 回合结果浮层 -->
  <view class="result-overlay {{showResult ? 'show' : ''}}" wx:if="{{showResult}}">
    <view class="result-card">
      <text class="result-icon">{{resultIcon}}</text>
      <text class="result-title">{{resultTitle}}</text>
      <text class="result-desc">{{resultDesc}}</text>
      <button class="btn-primary" bindtap="onDismissResult">知道了</button>
    </view>
  </view>
</view>
