.game-container {
  display: flex; flex-direction: column; height: 100vh;
  padding-top: var(--status-bar-height);
}
.opponents-area {
  display: flex; justify-content: space-around;
  padding: 20rpx; background: rgba(0,0,0,0.2);
}
.table-center {
  flex: 1; display: flex; flex-direction: column;
  align-items: center; justify-content: center; gap: 16rpx;
}
.target-rank { text-align: center; }
.rank-label { font-size: 24rpx; color: #8b7355; display: block; }
.rank-value { font-size: 80rpx; font-weight: bold; color: #c9a84c; }
.pile-info, .round-info { font-size: 26rpx; color: #8b7355; }
.hand-area { padding: 20rpx 0; background: rgba(0,0,0,0.3); }
.hand-cards { display: flex; justify-content: center; gap: 8rpx; padding: 0 20rpx; }
.card-wrapper { width: 120rpx; transition: transform 0.2s; }
.card-wrapper.selected { transform: translateY(-30rpx); }
