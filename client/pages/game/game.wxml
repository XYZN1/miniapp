<view class="game-container">
  <view class="opponents-area">
    <player-seat
      wx:for="{{opponents}}" wx:key="id"
      nickname="{{item.nickname}}"
      lives="{{item.lives}}"
      cardCount="{{item.handCardCount}}"
      isActive="{{item.id === currentPlayerId}}"
      isAlive="{{item.isAlive}}"
    />
  </view>

  <view class="table-center">
    <view class="target-rank">
      <text class="rank-label">当前点数</text>
      <text class="rank-value">{{targetRank}}</text>
    </view>
    <view class="pile-info">桌面牌堆：{{centralPileCount}} 张</view>
    <view class="round-info">第 {{roundNumber}} 轮</view>
  </view>

  <view class="hand-area">
    <view class="hand-cards">
      <view class="card-wrapper {{item.selected ? 'selected' : ''}}"
        wx:for="{{handCards}}" wx:key="id"
        bindtap="onSelectCard" data-id="{{item.id}}">
        <card cardId="{{item.id}}" faceUp="{{true}}" />
      </view>
    </view>
  </view>

  <action-panel
    isMyTurn="{{isMyTurn}}"
    gamePhase="{{gamePhase}}"
    selectedCards="{{selectedCards}}"
    bind:playcards="onPlayCards"
    bind:challenge="onChallenge"
    bind:follow="onFollow"
    bind:pass="onPass"
  />
</view>
