.container{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:100vh;padding:40rpx;}
.logo-section{text-align:center;margin-bottom:80rpx;}
.logo-icon{font-size:120rpx;display:block;margin-bottom:20rpx;}
.title{font-size:64rpx;font-weight:bold;color:#c9a84c;letter-spacing:8rpx;}
.subtitle{font-size:28rpx;color:#8b7355;margin-top:16rpx;display:block;}
.action-section{width:100%;max-width:500rpx;}
.input-group{margin-bottom:40rpx;}
.room-input{background:rgba(255,255,255,0.08);border:2rpx solid #5a4a3a;border-radius:16rpx;padding:24rpx 32rpx;font-size:36rpx;color:#e8d5b7;text-align:center;letter-spacing:8rpx;}
.btn-group{display:flex;flex-direction:column;gap:24rpx;}
.btn-group button{width:100%;}
.rules-link{margin-top:60rpx;font-size:26rpx;color:#8b7355;text-decoration:underline;}
